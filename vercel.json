{
  "rewrites": [
    { "source": "/pack/:path*",          "destination": "/api/pack/:path*" },
    { "source": "/telegram/:path*",      "destination": "/api/telegram/:path*" },
    { "source": "/check-licence/:path*", "destination": "/api/licence/:path*" },
