{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-TOKEN, X-ADMIN-TOKEN, Authorization" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/api/admin", "destination": "/api/admin.js" },
    { "source": "/config", "destination": "/api/config" },
    { "source": "/check-licence/v2/check", "destination": "/api/check-licence/v2/check.js" }
  ]
}
